# Copy this file to ".env" and paste your OpenAI API key.
# In Vite, only variables prefixed with VITE_ are exposed to the app.
#
# NOTE: this ships the key to the browser. Fine for a private prototype/demo.
# For a real pilot, move the OpenAI calls in src/lib/openai.ts behind a tiny
# serverless function and call that instead. See README "Security".

VITE_OPENAI_API_KEY=sk-paste-your-key-here

# Optional overrides (sensible defaults already set):
# VITE_TTS_MODEL=tts-1-hd
# VITE_TTS_VOICE=shimmer
# VITE_VISION_MODEL=gpt-4o-mini
# VITE_CHAT_MODEL=gpt-4o-mini
