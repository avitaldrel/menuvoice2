# Copy this file to ".env" and paste your OpenAI API key.
# In Vite, only variables prefixed with VITE_ are exposed to the app.
#
# NOTE: this ships the key to the browser. Fine for a private prototype/demo.
# For a real pilot, move the OpenAI calls in src/lib/openai.ts behind a tiny
# serverless function and call that instead. See README "Security".

VITE_OPENAI_API_KEY=sk-paste-your-key-here

# Google Sign-In (optional — if omitted, login falls back to email-only)
# Get from console.cloud.google.com → Credentials → OAuth 2.0 Client ID
VITE_GOOGLE_CLIENT_ID=paste-your-google-client-id-here.apps.googleusercontent.com

# Vercel Postgres — set automatically when a Postgres (Neon) store is linked.
# For local dev with `vercel dev`, this is injected from the linked store.
# Server-side only (no VITE_ prefix). api/events.ts uses this.
# Note: @vercel/postgres is deprecated; the env var name is the same for
# the Neon-native integration. See https://neon.com/docs/guides/vercel-postgres-transition-guide
POSTGRES_URL=

# Vercel Blob — set automatically when a Blob store is linked.
# Server-side only. api/upload-image.ts uses this.
BLOB_READ_WRITE_TOKEN=

# Optional overrides (sensible defaults already set):
# VITE_TTS_MODEL=tts-1-hd
# VITE_TTS_VOICE=shimmer
# VITE_VISION_MODEL=gpt-4o-mini
# VITE_CHAT_MODEL=gpt-4o-mini

# Server-side voice provider keys. Set these in Vercel without VITE_.
# CARTESIA_API_KEY=sk_car_...
# CARTESIA_VOICE_ID=
# CARTESIA_TTS_ENABLED=false
# CARTESIA_STT_ENABLED=false
# CARTESIA_REALTIME_STT_ENABLED=false
# Estimated hours before an exhausted key is eligible to retry (default 720 = 30 days).
# CARTESIA_KEY_RECOVERY_HOURS=720
# Protected-dashboard account labels and optional live credit details. Repeat _1 through _10.
# Every free key defaults to 20,000 credits. MenuVoice tracks an estimate from successful
# TTS requests (approximately one credit per character) when no admin key is configured.
# Cartesia's usage endpoint requires an admin key; standard sk_car_ keys return 401.
# CARTESIA_API_KEY_EMAIL_1=account@example.com
# CARTESIA_ADMIN_API_KEY_1=sk_car_admin_...
# CARTESIA_MONTHLY_CREDITS_1=20000
# CARTESIA_CREDIT_RESET_DAY_1=1

# Internal email delivery and alerts.
# RESEND_API_KEY=
# RESEND_FROM=MenuVoice <alerts@menuvoice.app>
# GMAIL_USER=
# GMAIL_APP_PASSWORD=
# REPORT_EMAIL_TO=2firemaster27@gmail.com
# Extra morning-report recipients, merged into REPORT_EMAIL_TO and deduped.
# REPORT_EMAIL_EXTRA=anibabug@gmail.com,ik8072369@gmail.com
# Accounts hidden from the report body (own testing + testers). Overrides the default.
# REPORT_EXCLUDE_EMAILS=2firemaster27@gmail.com,avitaldrel@gmail.com,mibrahim.dev17@gmail.com,anibabug@gmail.com,ik8072369@gmail.com
# Host used to build one-click keyed dashboard links in the email (default menuvoice-sigma.vercel.app).
# REPORT_PUBLIC_HOST=menuvoice-sigma.vercel.app
# CARTESIA_ALERT_EMAIL_TO=2firemaster27@gmail.com
# CARTESIA_ALERT_COOLDOWN_SECONDS=21600
