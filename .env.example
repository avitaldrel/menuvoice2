# Copy this file to ".env" and paste your OpenAI API key.
# In Vite, only variables prefixed with VITE_ are exposed to the app.
#
# NOTE: this ships the key to the browser. Fine for a private prototype/demo.
# For a real pilot, move the OpenAI calls in src/lib/openai.ts behind a tiny
# serverless function and call that instead. See README "Security".

VITE_OPENAI_API_KEY=sk-paste-your-key-here

# Google Sign-In (optional — if omitted, login falls back to email-only)
# Get from console.cloud.google.com → Credentials → OAuth 2.0 Client ID
VITE_GOOGLE_CLIENT_ID=paste-your-google-client-id-here.apps.googleusercontent.com

# Vercel Postgres — set automatically when a Postgres (Neon) store is linked.
# For local dev with `vercel dev`, this is injected from the linked store.
# Server-side only (no VITE_ prefix). api/events.ts uses this.
# Note: @vercel/postgres is deprecated; the env var name is the same for
# the Neon-native integration. See https://neon.com/docs/guides/vercel-postgres-transition-guide
POSTGRES_URL=

# Vercel Blob — set automatically when a Blob store is linked.
# Server-side only. api/upload-image.ts uses this.
BLOB_READ_WRITE_TOKEN=

# Optional overrides (sensible defaults already set):
# VITE_TTS_MODEL=tts-1-hd
# VITE_TTS_VOICE=shimmer
# VITE_VISION_MODEL=gpt-4o-mini
# VITE_CHAT_MODEL=gpt-4o-mini
